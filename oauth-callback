<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NextAura — Connecting…</title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #0a0a0a;
      color: #e5e5e5;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
    }
    .card {
      background: #111;
      border: 1px solid #222;
      border-radius: 12px;
      padding: 2.5rem 3rem;
      text-align: center;
      max-width: 400px;
      width: 90%;
    }
    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid #333;
      border-top-color: #6366f1;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 1.5rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    h1 { font-size: 1.25rem; font-weight: 600; margin: 0 0 0.5rem; }
    p  { font-size: 0.875rem; color: #888; margin: 0; }
    .error { color: #f87171; }
  </style>
</head>
<body>
  <div class="card">
    <div class="spinner" id="spinner"></div>
    <h1 id="title">Finishing connection…</h1>
    <p id="msg">Handing off to the NextAura desktop app.</p>
  </div>
  <script>
    (function () {
      var LOCAL = 'http://127.0.0.1:7823/oauth/callback';

      var params = new URLSearchParams(window.location.search);
      var code  = params.get('code');
      var state = params.get('state');
      var error = params.get('error');
      var errorDesc = params.get('error_description');

      if (error) {
        document.getElementById('spinner').style.display = 'none';
        document.getElementById('title').textContent = 'Connection failed';
        document.getElementById('msg').innerHTML =
          '<span class="error">' + error + (errorDesc ? ': ' + errorDesc : '') + '</span>';
        return;
      }

      if (!code || !state) {
        document.getElementById('spinner').style.display = 'none';
        document.getElementById('title').textContent = 'Missing parameters';
        document.getElementById('msg').innerHTML =
          '<span class="error">No authorization code received from provider.</span>';
        return;
      }

      var target = LOCAL + '?code=' + encodeURIComponent(code) + '&state=' + encodeURIComponent(state);
      window.location.replace(target);
    })();
  </script>
</body>
</html>
